# =============================================================================
# Bun + TypeScript + ESM + bun:sqlite
# =============================================================================

# -----------------------------------------------------------------------------
# Bun
# -----------------------------------------------------------------------------
node_modules/
bun.lockb          # 二进制 lockfile，按团队习惯决定是否提交
.bun-cache/

# -----------------------------------------------------------------------------
# TypeScript 编译产物
# -----------------------------------------------------------------------------
dist/
build/
out/
*.js.map
*.d.ts.map

# 如果你用 tsc 输出（非 bun build），排除编译结果
# 若源码全是 .ts 且用 bun 直接运行，可视情况打开下面这行
# *.js

# -----------------------------------------------------------------------------
# SQLite 数据库文件（bun:sqlite）
# -----------------------------------------------------------------------------
*.db
*.db-shm          # WAL 共享内存文件
*.db-wal          # WAL 日志文件
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# 环境变量 & 密钥
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
# 保留示例文件（通常应提交）
# !.env.example

# -----------------------------------------------------------------------------
# 日志 & 临时文件
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

tmp/
temp/
.tmp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# 测试 & 覆盖率
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# 编辑器 & IDE
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json   # 可提交推荐插件列表
!.vscode/settings.json     # 按需决定

# JetBrains（WebStorm / IDEA）
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 杂项
# -----------------------------------------------------------------------------
*.tsbuildinfo      # tsc 增量编译缓存
.cache/
.turbo/
